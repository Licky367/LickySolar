        <table>
          <thead>
            <tr>
              <th>Date</th>

              <% if(mode === "predicted_power"){ %>
                <th>GHI (kWh/m²/day)</th>
                <th>Panel Area (m²)</th>
                <th>Predicted Output (kWh/day)</th>
                <th>Temperature (°C)</th>
              <% } else { %>
                <th>GHI (kWh/m²/day)</th>
                <th>DNI (kWh/m²/day)</th>
                <th>DHI (kWh/m²/day)</th>
                <th>Temperature (°C)</th>
              <% } %>

            </tr>
          </thead>
          <tbody>
            <% weekData.forEach(row => { %>
              <tr>
                <td><%= row.date %></td>

                <% if(mode === "predicted_power"){ %>
                  <td><%= row.ghi %></td>
                  <td><%= area || 0 %></td>
                  <td><%= ((row.ghi || 0) * (area || 0)).toFixed(2) %></td>
                  <td><%= row.temp %></td>
                <% } else { %>
                  <td><%= row.ghi %></td>
                  <td><%= row.dni %></td>
                  <td><%= row.dhi %></td>
                  <td><%= row.temp %></td>
                <% } %>

              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="empty">No data found for this week.</div>
    <% } %>
  </div>


  <!-- =============================== -->
  <!-- MONTH RESULTS -->
  <!-- =============================== -->
  <div class="card">
    <div class="section-title">Month Results</div>

    <% if(monthData && monthData.length > 0){ %>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Date</th>

              <% if(mode === "predicted_power"){ %>
                <th>GHI (kWh/m²/day)</th>
                <th>Panel Area (m²)</th>
                <th>Predicted Output (kWh/day)</th>
                <th>Temperature (°C)</th>
              <% } else { %>
                <th>GHI (kWh/m²/day)</th>
                <th>DNI (kWh/m²/day)</th>
                <th>DHI (kWh/m²/day)</th>
                <th>Temperature (°C)</th>
              <% } %>

            </tr>
          </thead>
          <tbody>
            <% monthData.forEach(row => { %>
              <tr>
                <td><%= row.date %></td>

                <% if(mode === "predicted_power"){ %>
                  <td><%= row.ghi %></td>
                  <td><%= area || 0 %></td>
                  <td><%= ((row.ghi || 0) * (area || 0)).toFixed(2) %></td>
                  <td><%= row.temp %></td>
                <% } else { %>
                  <td><%= row.ghi %></td>
                  <td><%= row.dni %></td>
                  <td><%= row.dhi %></td>
                  <td><%= row.temp %></td>
                <% } %>

              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="empty">No data found for this month.</div>
    <% } %>
  </div>


  <!-- =============================== -->
  <!-- YEAR RESULTS -->
  <!-- =============================== -->
  <div class="card">
    <div class="section-title">Year Results</div>

    <% if(yearData && yearData.length > 0){ %>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Date</th>

              <% if(mode === "predicted_power"){ %>
                <th>GHI (kWh/m²/day)</th>
                <th>Panel Area (m²)</th>
                <th>Predicted Output (kWh/day)</th>
                <th>Temperature (°C)</th>
              <% } else { %>
                <th>GHI (kWh/m²/day)</th>
                <th>DNI (kWh/m²/day)</th>
                <th>DHI (kWh/m²/day)</th>
                <th>Temperature (°C)</th>
              <% } %>

            </tr>
          </thead>
          <tbody>
            <% yearData.forEach(row => { %>
              <tr>
                <td><%= row.date %></td>

                <% if(mode === "predicted_power"){ %>
                  <td><%= row.ghi %></td>
                  <td><%= area || 0 %></td>
                  <td><%= ((row.ghi || 0) * (area || 0)).toFixed(2) %></td>
                  <td><%= row.temp %></td>
                <% } else { %>
                  <td><%= row.ghi %></td>
                  <td><%= row.dni %></td>
                  <td><%= row.dhi %></td>
                  <td><%= row.temp %></td>
                <% } %>

              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="empty">No data found for this year.</div>
    <% } %>
  </div>

</div>