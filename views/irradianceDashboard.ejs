<% layout('layout', { title: title }) %>

<style>
.page{
  max-width:1100px;
  margin:auto;
}

.card{
  background:#fff;
  padding:25px;
  border-radius:14px;
  box-shadow:0 8px 20px rgba(0,0,0,.05);
  margin-bottom:20px;
}

h2{
  font-size:22px;
  margin-bottom:10px;
}

.filters{
  display:flex;
  gap:10px;
  flex-wrap:wrap;
  margin-bottom:20px;
}

.filters input,
.filters select{
  padding:10px;
  border:1px solid #ddd;
  border-radius:10px;
  font-size:15px;
  min-width:160px;
}

.filters button{
  padding:10px 18px;
  border:none;
  background:#111;
  color:#fff;
  border-radius:10px;
  cursor:pointer;
  font-size:15px;
}

.filters button:hover{
  opacity:.9;
}

.table-wrap{
  overflow-x:auto;
  margin-top:10px;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: thin;
}

.table-wrap::-webkit-scrollbar{
  height:6px;
}

.table-wrap::-webkit-scrollbar-thumb{
  background:#ccc;
  border-radius:20px;
}

table{
  width:100%;
  border-collapse:collapse;
  min-width:850px;
}

table th, table td{
  padding:12px;
  border-bottom:1px solid #eee;
  text-align:left;
  font-size:14px;
  white-space:nowrap;
}

table th{
  background:#f8f8f8;
  font-weight:600;
}

.section-title{
  font-size:17px;
  font-weight:600;
  margin-bottom:10px;
  color:#222;
}

.empty{
  padding:12px;
  background:#f9f9f9;
  border-radius:10px;
  font-size:14px;
  color:#555;
}

.badge{
  padding:4px 10px;
  border-radius:20px;
  font-size:12px;
  font-weight:600;
  background:#f0f0f0;
  display:inline-block;
  margin-right:6px;
  margin-top:5px;
}

.error{
  padding:12px;
  background:#ffe8e8;
  border:1px solid #ffbcbc;
  border-radius:10px;
  color:#9b1c1c;
  font-size:14px;
  margin-top:10px;
}
</style>

<div class="page">

  <!-- =============================== -->
  <!-- PAGE HEADER -->
  <!-- =============================== -->
  <div class="card">
    <h2>Solar Forecast Dashboard</h2>
    <p style="margin:0;color:#555;font-size:14px;">
      Enter GPS coordinates and filter by date. Choose to view either solar irradiance or predicted panel output (100% efficiency).
    </p>

    <% if(error){ %>
      <div class="error"><%= error %></div>
    <% } %>
  </div>

  <!-- =============================== -->
  <!-- FILTER FORM -->
  <!-- =============================== -->
  <div class="card">
    <div class="section-title">Filter by GPS, Date & Mode</div>

    <form class="filters" method="GET" action="/irradiance">

      <input type="number" step="0.000001" name="lat"
        placeholder="Latitude"
        value="<%= lat || '' %>" required>

      <input type="number" step="0.000001" name="lon"
        placeholder="Longitude"
        value="<%= lon || '' %>" required>

      <input type="date" name="date"
        value="<%= selectedDate || '' %>" required>

      <select name="mode" required>
        <option value="irradiance" <%= mode === 'irradiance' ? 'selected' : '' %>>
          Solar Irradiance
        </option>
        <option value="predicted_power" <%= mode === 'predicted_power' ? 'selected' : '' %>>
          Predicted Panel Output (100% Efficiency)
        </option>
      </select>

      <input type="number" step="0.01" name="area"
        placeholder="Panel Area (m²)"
        value="<%= area || '' %>">

      <button type="submit">Filter</button>
    </form>

    <div style="margin-top:10px;">
      <% if(lat && lon){ %>
        <span class="badge">Lat: <%= lat %></span>
        <span class="badge">Lon: <%= lon %></span>
      <% } %>

      <% if(selectedDate){ %>
        <span class="badge">Date: <%= selectedDate %></span>
      <% } %>

      <% if(mode){ %>
        <span class="badge">Mode: <%= mode %></span>
      <% } %>

      <% if(mode === 'predicted_power'){ %>
        <span class="badge">Area: <%= area || 0 %> m²</span>
      <% } %>
    </div>

    <p style="margin-top:10px;color:#666;font-size:13px;">
      Note: NASA POWER provides daily irradiance in <b>kWh/m²/day</b>. Predicted output is computed as:
      <b>GHI × Panel Area</b> (assuming 100% efficiency).
    </p>
  </div>


  <!-- =============================== -->
  <!-- DAY RESULTS -->
  <!-- =============================== -->
  <div class="card">
    <div class="section-title">Day Results</div>

    <% if(dayData && dayData.length > 0){ %>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Date</th>

              <% if(mode === "predicted_power"){ %>
                <th>GHI (kWh/m²/day)</th>
                <th>Panel Area (m²)</th>
                <th>Predicted Output (kWh/day)</th>
                <th>Temperature (°C)</th>
              <% } else { %>
                <th>GHI (kWh/m²/day)</th>
                <th>DNI (kWh/m²/day)</th>
                <th>DHI (kWh/m²/day)</th>
                <th>Temperature (°C)</th>
              <% } %>

            </tr>
          </thead>
          <tbody>
            <% dayData.forEach(row => { %>
              <tr>
                <td><%= row.date %></td>

                <% if(mode === "predicted_power"){ %>
                  <td><%= row.ghi %></td>
                  <td><%= area || 0 %></td>
                  <td><%= ((row.ghi || 0) * (area || 0)).toFixed(2) %></td>
                  <td><%= row.temp %></td>
                <% } else { %>
                  <td><%= row.ghi %></td>
                  <td><%= row.dni %></td>
                  <td><%= row.dhi %></td>
                  <td><%= row.temp %></td>
                <% } %>

              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="empty">No data found for this day.</div>
    <% } %>
  </div>


  <!-- =============================== -->
  <!-- WEEK RESULTS -->
  <!-- =============================== -->
  <div class="card">
    <div class="section-title">Week Results</div>

    <% if(weekData && weekData.length > 0){ %>
