<div class="card" style="max-width:500px;margin:auto;">

<h2 style="margin-bottom:20px;">
Signup
</h2>

<form action="/signup" method="POST">

<div class="form-group">

<label>Name</label>

<input
type="text"
name="name"
class="form-control"
required
/>

</div>

<div class="form-group">

<label>Email</label>

<input
type="email"
name="email"
class="form-control"
required
/>

</div>

<div class="form-group">

<label>Phone</label>

<input
type="text"
name="phone"
class="form-control"
required
/>

</div>

<div class="form-group">

<label>Password</label>

<input
type="password"
name="password"
class="form-control"
required
/>

</div>

<button class="btn btn-green">
Signup
</button>

</form>

<br>

<p>
Already have an account?
<a href="/login">
Login
</a>
</p>

</div>