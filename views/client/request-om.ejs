<div class="card">

<h3 style="margin-bottom:20px;">
Request O&M Support
</h3>

<form action="/om/request" method="POST">

<div class="form-group">

<label>Issue Title</label>

<input
type="text"
name="title"
class="form-control"
required
/>

</div>

<div class="form-group">

<label>Description</label>

<textarea
name="description"
class="form-control"
rows="6"
required
></textarea>

</div>

<button class="btn btn-green">
Submit Request
</button>

</form>

</div>