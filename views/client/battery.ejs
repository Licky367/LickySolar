<div class="grid">

<!-- BATTERY LEVEL -->
<div class="card">

<div class="card-title">
Battery Level
</div>

<div class="card-value">
<%= latest?.percentage || 0 %>%
</div>

<div style="
margin-top:18px;
background:#edf2f7;
height:14px;
border-radius:20px;
overflow:hidden;
">

<div style="
height:100%;
width:<%= latest?.percentage || 0 %>%;

background:
<%= (latest?.percentage || 0) > 60
? '#0c5f2c'
: (latest?.percentage || 0) > 30
? '#d4a017'
: '#d80000'
%>;

border-radius:20px;
transition:.4s;
">

</div>

</div>

</div>


<!-- VOLTAGE -->
<div class="card">

<div class="card-title">
Battery Voltage
</div>

<div class="card-value">
<%= latest?.voltage || 0 %> V
</div>

</div>


<!-- CURRENT -->
<div class="card">

<div class="card-title">
Battery Current
</div>

<div class="card-value">
<%= latest?.current || 0 %> A
</div>

</div>


<!-- STATUS -->
<div class="card">

<div class="card-title">
Battery Status
</div>

<div class="card-value" style="
font-size:22px;
text-transform:capitalize;
">

<%= latest?.status || 'idle' %>

</div>

</div>

</div>

<br>

<!-- HEALTH + TEMP -->
<div class="grid">

<div class="card">

<h3>Battery Health</h3>

<h2 style="text-transform:capitalize;">
<%= latest?.health || 'Unknown' %>
</h2>

</div>

<div class="card">

<h3>Temperature</h3>

<h2>
<%= latest?.temperature || 0 %> °C
</h2>

</div>

</div>

<br>

<!-- HISTORY -->
<div class="card">

<h3>Battery History</h3>

<div class="table-wrapper">

<table>

<tr>
<th>Voltage</th>
<th>Current</th>
<th>Battery %</th>
<th>Status</th>
<th>Health</th>
<th>Temp</th>
<th>Date</th>
</tr>

<% (readings || []).forEach(r => { %>

<tr>

<td><%= r.voltage %> V</td>
<td><%= r.current %> A</td>
<td><%= r.percentage %>%</td>
<td><%= r.status %></td>
<td><%= r.health %></td>
<td><%= r.temperature %> °C</td>
<td><%= new Date(r.createdAt).toLocaleString() %></td>

</tr>

<% }) %>

</table>

</div>

</div>

<br>

<!-- STATS -->
<div class="grid">

<div class="card">
<h3>Charging</h3>
<p><%= stats.charging %></p>
</div>

<div class="card">
<h3>Discharging</h3>
<p><%= stats.discharging %></p>
</div>

<div class="card">
<h3>Idle</h3>
<p><%= stats.idle %></p>
</div>

<div class="card">
<h3>Fault</h3>
<p><%= stats.fault %></p>
</div>

</div>