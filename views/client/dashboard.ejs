<div class="grid">

<div class="card">

<div class="card-title">
Solar Power
</div>

<div class="card-value">
<%= data.solar?.power || 0 %> W
</div>

</div>

<div class="card">

<div class="card-title">
Battery
</div>

<div class="card-value">
<%= data.battery?.percentage || 0 %>%
</div>

</div>

<div class="card">

<div class="card-title">
Current Source
</div>

<div class="card-value">
<%= data.deviceStatus?.activeSource || 'N/A' %>
</div>

</div>

<div class="card">

<div class="card-title">
Faults
</div>

<div class="card-value">
<%= data.faults.length %>
</div>

</div>

</div>

<br>

<div class="card">

<h3 style="margin-bottom:20px;">
System Status
</h3>

<table>

<tr>
<th>Component</th>
<th>Status</th>
</tr>

<tr>
<td>Solar</td>
<td>
<%= data.deviceStatus?.solarActive
? 'Active'
: 'Offline'
%>
</td>
</tr>

<tr>
<td>Battery</td>
<td>
<%= data.deviceStatus?.batteryActive
? 'Active'
: 'Offline'
%>
</td>
</tr>

<tr>
<td>Grid</td>
<td>
<%= data.deviceStatus?.gridActive
? 'Available'
: 'Unavailable'
%>
</td>
</tr>

<tr>
<td>Inverter</td>
<td>
<%= data.deviceStatus?.inverterStatus %>
</td>
</tr>

</table>

</div>