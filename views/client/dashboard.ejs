<div class="grid">

<!-- SOLAR -->
<div class="card">
    <div class="card-title">Solar Power</div>
    <div class="card-value">
        <%= dashboard.solar?.power || 0 %> W
    </div>
</div>

<!-- BATTERY -->
<div class="card">
    <div class="card-title">Battery</div>
    <div class="card-value">
        <%= dashboard.battery?.percentage || 0 %>%
    </div>
</div>

<!-- CURRENT SOURCE -->
<div class="card">
    <div class="card-title">Current Source</div>
    <div class="card-value">
        <%= device?.activeSource || 'N/A' %>
    </div>
</div>

<!-- FAULT COUNT -->
<div class="card">
    <div class="card-title">Faults</div>
    <div class="card-value">
        <%= dashboard.faults?.length || 0 %>
    </div>
</div>

</div>

<br>

<!-- SYSTEM STATUS -->
<div class="card">

<h3 style="margin-bottom:20px;">
System Status
</h3>

<table>

<tr>
    <th>Component</th>
    <th>Status</th>
</tr>

<tr>
    <td>Solar</td>
    <td>
        <%= device?.solarActive
            ? 'Active'
            : 'Offline'
        %>
    </td>
</tr>

<tr>
    <td>Battery</td>
    <td>
        <%= device?.batteryActive
            ? 'Active'
            : 'Offline'
        %>
    </td>
</tr>

<tr>
    <td>Grid</td>
    <td>
        <%= device?.gridActive
            ? 'Available'
            : 'Unavailable'
        %>
    </td>
</tr>

<tr>
    <td>Inverter</td>
    <td>
        <%= device?.inverterStatus || 'Unknown' %>
    </td>
</tr>

<tr>
    <td>Internet</td>
    <td>
        <%= device?.internetStatus === 'online'
            ? '🟢 Online'
            : '🔴 Offline'
        %>
    </td>
</tr>

<tr>
    <td>Last Update</td>
    <td>
        <%= device?.lastHeartbeat
            ? new Date(device.lastHeartbeat).toLocaleString()
            : 'N/A'
        %>
    </td>
</tr>

</table>

</div>