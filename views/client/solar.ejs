<div class="grid">

<!-- SOLAR POWER -->
<div class="card">
    <div class="card-title">Solar Output Power</div>
    <div class="card-value">
        <%= latest?.power || 0 %> W
    </div>
</div>

<!-- VOLTAGE -->
<div class="card">
    <div class="card-title">Solar Voltage</div>
    <div class="card-value">
        <%= latest?.voltage || 0 %> V
    </div>
</div>

<!-- CURRENT -->
<div class="card">
    <div class="card-title">Solar Current</div>
    <div class="card-value">
        <%= latest?.current || 0 %> A
    </div>
</div>

<!-- EFFICIENCY -->
<div class="card">
    <div class="card-title">Efficiency</div>
    <div class="card-value">
        <%= latest?.efficiency || 0 %>%
    </div>
</div>

</div>

<br>

<!-- STATUS + TEMP -->
<div class="grid">

<div class="card">

<h3>Panel Status</h3>

<h2 style="text-transform:capitalize;">
<%= latest?.status || "Unknown" %>
</h2>

</div>

<div class="card">

<h3>Temperature</h3>

<h2>
<%= latest?.temperature || 0 %> °C
</h2>

</div>

</div>

<br>

<!-- HISTORY -->
<div class="card">

<h3>Solar History</h3>

<div class="table-wrapper">

<table>

<tr>
<th>Voltage</th>
<th>Current</th>
<th>Power</th>
<th>Efficiency</th>
<th>Status</th>
<th>Temp</th>
<th>Date</th>
</tr>

<% (readings || []).forEach(r => { %>

<tr>

<td><%= r.voltage %> V</td>
<td><%= r.current %> A</td>
<td><%= r.power %> W</td>
<td><%= r.efficiency %>%</td>
<td><%= r.status %></td>
<td><%= r.temperature %> °C</td>
<td>
<%= new Date(r.createdAt).toLocaleString() %>
</td>

</tr>

<% }) %>

</table>

</div>

</div>

<br>

<!-- STATS -->
<div class="grid">

<div class="card">

<h3>Active</h3>
<p><%= stats.active %></p>

</div>

<div class="card">

<h3>Low</h3>
<p><%= stats.low %></p>

</div>

<div class="card">

<h3>Fault</h3>
<p><%= stats.fault %></p>

</div>

</div>