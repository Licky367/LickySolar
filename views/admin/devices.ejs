<div class="card">

<!-- =========================
     HEADER
========================= -->
<div style="
display:flex;
justify-content:space-between;
align-items:center;
margin-bottom:20px;
flex-wrap:wrap;
gap:10px;
">

<h3>Devices</h3>

<div>

<a href="/admin/devices/create" class="btn btn-green">
New Device
</a>

<a href="/admin/devices/assign" class="btn btn-green">
Assign Device
</a>

</div>

</div>


<!-- =========================
     TABLE
========================= -->
<div style="overflow-x:auto;">

<table>

<tr>
<th>Device ID</th>
<th>Name</th>
<th>Location</th>
<th>Client</th>
<th>Status</th>
<th>Source</th>
<th>Internet</th>
<th>MAC</th>
<th>Action</th>
</tr>

<% devices.forEach(d => { %>

<tr>

<!-- DEVICE ID -->
<td>
<strong><%= d.deviceId %></strong>
</td>

<!-- NAME -->
<td>
<%= d.name || "-" %>
</td>

<!-- LOCATION -->
<td>
<%= d.location || "-" %>
</td>

<!-- CLIENT -->
<td>
<%= d.clientId ? d.clientId.name : "Unassigned" %>
</td>

<!-- ASSIGNMENT STATUS -->
<td>

<span style="
padding:6px 10px;
border-radius:20px;
font-size:12px;
font-weight:bold;

background:<%= d.assigned ? '#e7fff0' : '#fff5d9' %>;
color:<%= d.assigned ? '#0c5f2c' : '#946200' %>;
">

<%= d.assigned ? "Assigned" : "Free" %>

</span>

</td>

<!-- ACTIVE SOURCE -->
<td>

<span style="
padding:6px 10px;
border-radius:20px;
font-size:12px;
font-weight:bold;

background:
<%= d.activeSource === 'solar'
? '#e7fff0'
: d.activeSource === 'battery'
? '#fff5d9'
: '#ffe5e5'
%>;

color:
<%= d.activeSource === 'solar'
? '#0c5f2c'
: d.activeSource === 'battery'
? '#946200'
: '#c40000'
%>;
">

<%= d.activeSource %>

</span>

</td>

<!-- INTERNET STATUS -->
<td>

<span style="
padding:6px 10px;
border-radius:20px;
font-size:12px;
font-weight:bold;

background:
<%= d.internetStatus === 'online'
? '#e7fff0'
: '#ffe5e5'
%>;

color:
<%= d.internetStatus === 'online'
? '#0c5f2c'
: '#c40000'
%>;
">

<%= d.internetStatus %>

</span>

</td>

<!-- MAC ADDRESS -->
<td style="font-size:12px;">
<%= d.macAddress || "-" %>
</td>

<!-- ACTION -->
<td>

<a href="/admin/devices/<%= d.deviceId %>/config"
   class="btn btn-green"
   style="padding:6px 12px;font-size:12px;">
   Configure
</a>

</td>

</tr>

<% }) %>

</table>

</div>

</div>