<div class="card">

<h2 style="margin-bottom:20px;">
Device Setup & Configuration
</h2>

<form action="/admin/devices/create" method="POST">

<div class="grid">

<div class="form-group">
<label>Device ID</label>
<input name="deviceId" class="form-control" required/>
</div>

<div class="form-group">
<label>Device Name</label>
<input name="name" class="form-control"/>
</div>

<div class="form-group">
<label>Location</label>
<input name="location" class="form-control"/>
</div>

<div class="form-group">
<label>MAC Address</label>
<input name="macAddress" class="form-control"/>
</div>

</div>

<br>

<button class="btn btn-green">
Create Device
</button>

</form>

</div>

<br>

<% if(device){ %>

<div class="card">

<h3>Device Credentials</h3>

<p><strong>Device ID:</strong> <%= device.deviceId %></p>
<p><strong>API Key:</strong> <%= device.apiKey %></p>
<p><strong>Server:</strong> <%= serverUrl %></p>

</div>

<br>

<div class="card">

<div style="display:flex;justify-content:space-between;">
<h3>ESP32 Firmware</h3>
<button onclick="copyCode()" class="btn btn-green">Copy</button>
</div>

<br>

<pre id="codeBlock" style="background:#111;color:#0f0;padding:20px;border-radius:10px;overflow:auto;max-height:600px;">

#include &lt;WiFi.h&gt;
#include &lt;HTTPClient.h&gt;

// =========================
// WIFI
// =========================
const char* ssid = "YOUR_WIFI";
const char* password = "YOUR_PASSWORD";

// =========================
// SERVER
// =========================
const char* baseUrl = "<%= serverUrl %>/api/device";

// =========================
// AUTH
// =========================
const char* deviceId = "<%= device.deviceId %>";
const char* apiKey   = "<%= device.apiKey %>";

// =========================
// PINS
// =========================
#define SOLAR_VOLT 34
#define BATTERY_VOLT 35
#define CURRENT_PIN 32

#define RELAY_SOLAR 25
#define RELAY_BATTERY 26
#define RELAY_GRID 27

// =========================
// SYSTEM STATE
// =========================
String activeSource = "solar";
unsigned long lastSwitchTime = 0;
const int switchDelay = 5000;

// =========================
// SETUP
// =========================
void setup(){

  Serial.begin(115200);

  pinMode(RELAY_SOLAR, OUTPUT);
  pinMode(RELAY_BATTERY, OUTPUT);
  pinMode(RELAY_GRID, OUTPUT);

  connectWiFi();
}

// =========================
// LOOP
// =========================
void loop(){

  float solarV = readVoltage(SOLAR_VOLT);
  float batteryV = readVoltage(BATTERY_VOLT);
  float current = readCurrent();

  float solarPower = solarV * current;
  float batteryPower = batteryV * current;
  float loadPower = batteryV * current;

  decideSource(solarV, batteryV, loadPower);

  sendSolar(solarV, current);
  sendBattery(batteryV, current);
  sendGrid(current);

  sendHeartbeat();

  delay(5000);
}

// =========================
// WIFI
// =========================
void connectWiFi(){

  WiFi.begin(ssid, password);

  while(WiFi.status() != WL_CONNECTED){
    delay(500);
  }
}

// =========================
// SENSOR FUNCTIONS
// =========================
float readVoltage(int pin){
  float raw = analogRead(pin);
  float voltage = raw * (3.3 / 4095.0) * 11; // calibrate
  return voltage;
}

float readCurrent(){
  float raw = analogRead(CURRENT_PIN);
  float current = raw * (3.3 / 4095.0);
  return current;
}

// =========================
// DECISION ENGINE
// =========================
void decideSource(float solarV, float batteryV, float loadPower){

  if(millis() - lastSwitchTime &lt; switchDelay){
    return;
  }

  String previous = activeSource;

  if(solarV &gt; 18){
    switchSolar();
  }
  else if(batteryV &gt; 12){
    switchBattery();
  }
  else{
    switchGrid();
  }

  if(previous != activeSource){
    lastSwitchTime = millis();
    sendTransition(previous, activeSource, solarV, batteryV, loadPower);
  }
}

// =========================
// SWITCHING
// =========================
void switchSolar(){
  digitalWrite(RELAY_SOLAR, HIGH);
  digitalWrite(RELAY_BATTERY, LOW);
  digitalWrite(RELAY_GRID, LOW);
  activeSource = "solar";
}

void switchBattery(){
  digitalWrite(RELAY_SOLAR, LOW);
  digitalWrite(RELAY_BATTERY, HIGH);
  digitalWrite(RELAY_GRID, LOW);
  activeSource = "battery";
}

void switchGrid(){
  digitalWrite(RELAY_SOLAR, LOW);
  digitalWrite(RELAY_BATTERY, LOW);
  digitalWrite(RELAY_GRID, HIGH);
  activeSource = "grid";
}

// =========================
// API SENDERS
// =========================
void sendSolar(float v, float c){
  send("/solar", "\"voltage\":" + String(v) + ",\"current\":" + String(c) + ",\"power\":" + String(v*c));
}

void sendBattery(float v, float c){
  send("/battery", "\"voltage\":" + String(v) + ",\"current\":" + String(c) + ",\"power\":" + String(v*c) + ",\"percentage\":" + String(map(v,11,13,0,100)));
}

void sendGrid(float c){
  send("/grid", "\"voltage\":220,\"current\":" + String(c) + ",\"power\":" + String(220*c) + ",\"frequency\":50");
}

void sendHeartbeat(){
  send("/heartbeat", "");
}

// =========================
// TRANSITION LOG
// =========================
void sendTransition(String from, String to, float solarV, float batteryV, float load){

  String data = "\"fromSource\":\""+from+"\",\"toSource\":\""+to+"\",\"reason\":\"auto\",\"solarVoltage\":"+String(solarV)+",\"batteryVoltage\":"+String(batteryV)+",\"gridVoltage\":220,\"loadPower\":"+String(load);

  send("/transition", data);
}

// =========================
// GENERIC SENDER
// =========================
void send(String endpoint, String extra){

  if(WiFi.status() != WL_CONNECTED) return;

  HTTPClient http;

  http.begin(String(baseUrl) + endpoint);
  http.addHeader("Content-Type", "application/json");

  String payload = "{";
  payload += "\"deviceId\":\"" + String(deviceId) + "\",";
  payload += "\"apiKey\":\"" + String(apiKey) + "\"";

  if(extra.length() &gt; 0){
    payload += "," + extra;
  }

  payload += "}";

  http.POST(payload);
  http.end();
}

</pre>

</div>

<% } %>

<script>
function copyCode(){
    const code = document.getElementById("codeBlock").innerText;
    navigator.clipboard.writeText(code);
    alert("Firmware copied");
}
</script>