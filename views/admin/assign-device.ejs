<div class="card">

<h3>Assign Device to Client</h3>

<p style="color:#666; margin-bottom:20px;">
Enter the device MAC address and the client's email to link them.
</p>

<form action="/admin/devices/assign" method="POST">

<!-- =========================
     MAC ADDRESS
========================= -->
<div class="form-group">

<label>Device MAC Address</label>

<input 
    type="text"
    name="macAddress"
    class="form-control"
    placeholder="e.g. 24:6F:28:AB:CD:EF"
    required
/>

<small style="color:#777;">
Find this using ESP32 → WiFi.macAddress()
</small>

</div>


<!-- =========================
     CLIENT EMAIL
========================= -->
<div class="form-group">

<label>Client Email</label>

<input 
    type="email"
    name="email"
    class="form-control"
    placeholder="e.g. client@email.com"
    required
/>

</div>


<!-- =========================
     SUBMIT
========================= -->
<button class="btn btn-green">
Assign Device
</button>

</form>

</div>