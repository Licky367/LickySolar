<div class="card">

<h3>Assign Device to Client</h3>

<p style="color:#666; margin-bottom:20px;">
Link a physical ESP32 device to a client account using its MAC address.
</p>

<form action="/admin/devices/assign" method="POST">

<div class="grid">

<!-- =========================
     MAC ADDRESS
========================= -->
<div class="form-group">

<label>Device MAC Address</label>

<input 
    type="text"
    name="macAddress"
    class="form-control"
    placeholder="e.g. 24:6F:28:AB:CD:EF"
    required
    pattern="^([0-9A-Fa-f]{2}:){5}[0-9A-Fa-f]{2}$"
/>

<small style="color:#777;">
Format: XX:XX:XX:XX:XX:XX (from ESP32 → WiFi.macAddress())
</small>

</div>


<!-- =========================
     CLIENT EMAIL
========================= -->
<div class="form-group">

<label>Client Email</label>

<input 
    type="email"
    name="email"
    class="form-control"
    placeholder="e.g. client@email.com"
    required
/>

<small style="color:#777;">
Device will be linked to this user
</small>

</div>

</div>

<br>

<!-- =========================
     SUBMIT
========================= -->
<button class="btn btn-green">
Assign Device
</button>

</form>

</div>


<br>


<!-- =========================
     HELPER INFO CARD
========================= -->
<div class="card">

<h3 style="margin-bottom:15px;">
How to Find MAC Address
</h3>

<pre style="
background:#111;
color:#0f0;
padding:15px;
border-radius:10px;
font-size:13px;
overflow:auto;
">

#include &lt;WiFi.h&gt;

void setup(){
  Serial.begin(115200);
  WiFi.begin("ssid","password");

  while(WiFi.status() != WL_CONNECTED){
    delay(1000);
  }

  Serial.println(WiFi.macAddress());
}

</pre>

<p style="color:#666; margin-top:10px;">
Upload this to ESP32 and check Serial Monitor.
</p>

</div>