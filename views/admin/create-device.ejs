<div class="card">

<h3>Register New Device</h3>

<p style="color:#666; margin-bottom:20px;">
Device ID and API Key will be generated automatically.
Use them to program the ESP32.
</p>

<form action="/admin/devices/create" method="POST">

<!-- NAME -->
<div class="form-group">
<label>Device Name</label>
<input 
    name="name" 
    class="form-control"
    placeholder="e.g. Solar System - House A"
/>
</div>

<!-- LOCATION -->
<div class="form-group">
<label>Installation Location</label>
<input 
    name="location" 
    class="form-control"
    placeholder="e.g. Nairobi, Rooftop"
/>
</div>

<!-- MAC ADDRESS -->
<div class="form-group">
<label>ESP32 MAC Address (Optional)</label>
<input 
    name="macAddress" 
    class="form-control"
    placeholder="e.g. 24:6F:28:AB:CD:EF"
/>

<small style="color:#777;">
You can get this from ESP32 using WiFi.macAddress()
</small>
</div>

<!-- SUBMIT -->
<button class="btn btn-green">
Create Device
</button>

</form>

</div>