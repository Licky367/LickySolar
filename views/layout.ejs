<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title><%= title || "SolarWatch" %></title>

<link
rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
/>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial,sans-serif;
}

body{
    background:#f4f7fb;
    color:#222;
}

/* =========================
   HEADER
========================= */

.header{
    position:fixed;
    top:0;
    left:0;
    right:0;
    height:70px;
    background:#0c5f2c;
    color:white;
    display:flex;
    align-items:center;
    justify-content:space-between;
    padding:0 25px;
    z-index:1200;
    box-shadow:0 4px 15px rgba(0,0,0,.1);
}

.header-title{
    font-size:24px;
    font-weight:bold;
}

.header-title span{
    color:#8fffb1;
}

.menu-btn{
    width:45px;
    height:45px;
    border:none;
    border-radius:10px;
    background:rgba(255,255,255,.12);
    color:white;
    cursor:pointer;
    font-size:20px;
    transition:.3s;
}

.menu-btn:hover{
    background:rgba(255,255,255,.2);
}

/* =========================
   SIDEBAR
========================= */

.sidebar{
    position:fixed;
    top:70px;
    right:-300px;
    width:280px;
    height:calc(100vh - 70px);
    background:#0c5f2c;
    color:white;
    padding:20px;
    overflow-y:auto;
    transition:.35s ease;
    z-index:1100;
    box-shadow:-5px 0 20px rgba(0,0,0,.15);
}

.sidebar.active{
    right:0;
}

.nav-links{
    display:flex;
    flex-direction:column;
    gap:10px;
}

.nav-links a{
    text-decoration:none;
    color:white;
    padding:14px;
    border-radius:12px;
    transition:.3s;
    display:flex;
    align-items:center;
    gap:12px;
    font-size:15px;
}

.nav-links a:hover{
    background:rgba(255,255,255,.15);
}

.nav-links a.active{
    background:white;
    color:#0c5f2c;
}

/* =========================
   OVERLAY
========================= */

.overlay{
    position:fixed;
    inset:0;
    background:rgba(0,0,0,.4);
    opacity:0;
    visibility:hidden;
    transition:.3s;
    z-index:1000;
}

.overlay.active{
    opacity:1;
    visibility:visible;
}

/* =========================
   MAIN
========================= */

.main{
    padding:95px 25px 90px;
    min-height:100vh;
}

/* =========================
   TOPBAR
========================= */

.topbar{
    background:white;
    padding:18px 25px;
    border-radius:18px;
    margin-bottom:25px;
    display:flex;
    justify-content:space-between;
    align-items:center;
    box-shadow:0 5px 20px rgba(0,0,0,.05);
    flex-wrap:wrap;
    gap:15px;
}

.topbar-right{
    display:flex;
    align-items:center;
    gap:15px;
    flex-wrap:wrap;
}

.badge{
    background:#e9fff0;
    color:#0c5f2c;
    padding:8px 14px;
    border-radius:30px;
    font-size:13px;
    font-weight:bold;
}

/* =========================
   ALERTS
========================= */

.alert{
    padding:14px;
    border-radius:12px;
    margin-bottom:20px;
}

.alert-success{
    background:#dfffe7;
    color:#0c5f2c;
}

.alert-error{
    background:#ffe5e5;
    color:#c40000;
}

/* =========================
   CARDS
========================= */

.grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:20px;
}

.card{
    background:white;
    border-radius:18px;
    padding:24px;
    box-shadow:0 6px 20px rgba(0,0,0,.05);
}

.card-title{
    color:#666;
    margin-bottom:10px;
    font-size:14px;
}

.card-value{
    font-size:32px;
    font-weight:bold;
    color:#0c5f2c;
}

/* =========================
   TABLES
========================= */

table{
    width:100%;
    border-collapse:collapse;
    background:white;
    border-radius:15px;
    overflow:hidden;
}

table th,
table td{
    padding:14px;
    border-bottom:1px solid #eee;
    text-align:left;
}

table th{
    background:#f7faf9;
}

/* =========================
   BUTTONS
========================= */

.btn{
    border:none;
    padding:12px 18px;
    border-radius:10px;
    cursor:pointer;
    text-decoration:none;
    display:inline-block;
}

.btn-green{
    background:#0c5f2c;
    color:white;
}

.btn-red{
    background:#d80000;
    color:white;
}

/* =========================
   FORMS
========================= */

.form-group{
    margin-bottom:18px;
}

.form-group label{
    display:block;
    margin-bottom:8px;
}

.form-control{
    width:100%;
    padding:14px;
    border-radius:12px;
    border:1px solid #ddd;
}

/* =========================
   FOOTER
========================= */

.footer{
    position:fixed;
    bottom:0;
    left:0;
    right:0;
    height:55px;
    background:#0c5f2c;
    color:white;
    display:flex;
    align-items:center;
    justify-content:center;
    font-size:14px;
    z-index:1200;
    box-shadow:0 -4px 15px rgba(0,0,0,.08);
}

/* =========================
   MOBILE
========================= */

@media(max-width:768px){

    .header{
        padding:0 18px;
    }

    .main{
        padding:90px 15px 85px;
    }

    .topbar{
        padding:16px;
    }

    .sidebar{
        width:100%;
        right:-100%;
    }

}

</style>

</head>

<body>

<!-- =========================
     HEADER
========================= -->

<header class="header">

<div class="header-title">
Solar<span>Watch</span>
</div>

<button class="menu-btn" id="menuBtn">
    <i class="fas fa-bars"></i>
</button>

</header>

<!-- =========================
     SIDEBAR
========================= -->

<div class="sidebar" id="sidebar">

<div class="nav-links">

<% if(currentUser){ %>

    <% if(currentUser.role === "client"){ %>

        <a href="/">
            <i class="fas fa-chart-line"></i>
            Dashboard
        </a>

        <a href="/solar/history">
            <i class="fas fa-solar-panel"></i>
            Solar
        </a>

        <a href="/battery/history">
            <i class="fas fa-battery-three-quarters"></i>
            Battery
        </a>

        <a href="/faults">
            <i class="fas fa-triangle-exclamation"></i>
            Faults
        </a>

        <a href="/om/request">
            <i class="fas fa-screwdriver-wrench"></i>
            Request O&M
        </a>

        <a href="/om/history">
            <i class="fas fa-clock-rotate-left"></i>
            O&M History
        </a>

    <% } %>

    <% if(
        currentUser.role === "admin" ||
        currentUser.role === "super_admin"
    ){ %>

        <a href="/admin">
            <i class="fas fa-chart-pie"></i>
            Dashboard
        </a>

        <a href="/admin/clients">
            <i class="fas fa-users"></i>
            Clients
        </a>

        <a href="/om/admin/om">
            <i class="fas fa-screwdriver-wrench"></i>
            O&M Requests
        </a>

        <a href="/admin/admins">
            <i class="fas fa-user-shield"></i>
            Admins
        </a>

        <% if(currentUser.role === "super_admin"){ %>

            <a href="/admin/invite-admin">
                <i class="fas fa-user-plus"></i>
                Invite Admin
            </a>

        <% } %>

    <% } %>

    <a href="/logout">
        <i class="fas fa-right-from-bracket"></i>
        Logout
    </a>

<% } %>

</div>

</div>

<!-- =========================
     OVERLAY
========================= -->

<div class="overlay" id="overlay"></div>

<!-- =========================
     MAIN
========================= -->

<div class="main">

<div class="topbar">

<div>
<h2><%= title %></h2>
</div>

<div class="topbar-right">

<% if(currentUser){ %>

<div class="badge">
<%= currentUser.role %>
</div>

<div>
<%= currentUser.name %>
</div>

<% } %>

</div>

</div>

<!-- =========================
     ALERTS
========================= -->

<% if(success.length > 0){ %>

<div class="alert alert-success">
<%= success %>
</div>

<% } %>

<% if(error.length > 0){ %>

<div class="alert alert-error">
<%= error %>
</div>

<% } %>

<!-- =========================
     BODY
========================= -->

<%- body %>

</div>

<!-- =========================
     FOOTER
========================= -->

<footer class="footer">
© <%= new Date().getFullYear() %> SolarWatch
</footer>

<script>

const menuBtn = document.getElementById("menuBtn");
const sidebar = document.getElementById("sidebar");
const overlay = document.getElementById("overlay");

menuBtn.addEventListener("click", () => {
    sidebar.classList.toggle("active");
    overlay.classList.toggle("active");
});

overlay.addEventListener("click", () => {
    sidebar.classList.remove("active");
    overlay.classList.remove("active");
});

</script>

</body>
</html>